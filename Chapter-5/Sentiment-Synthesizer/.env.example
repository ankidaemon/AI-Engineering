# Sentiment Synthesizer - Environment Configuration Template
# Copy this file to .env and fill in your credentials

# ============================================================================
# TWITTER API CONFIGURATION
# Get credentials from: https://developer.twitter.com/en/portal/dashboard
# ============================================================================

# Twitter API Key (also called API Key)
TWITTER_API_KEY=your_twitter_api_key_here

# Twitter API Secret Key
TWITTER_API_SECRET=your_twitter_api_secret_here

# Twitter Bearer Token (for API v2)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Twitter API Query Parameters
TWITTER_QUERY=sentiment analysis
TWITTER_COUNT=100
TWITTER_LANG=en

# ============================================================================
# REDDIT API CONFIGURATION
# Get credentials from: https://reddit.com/prefs/apps
# ============================================================================

# Reddit Client ID
REDDIT_CLIENT_ID=your_reddit_client_id_here

# Reddit Client Secret
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# Reddit User Agent (format: "app_name/version by username")
REDDIT_USER_AGENT=sentiment-synthesizer/1.0.0 by your_reddit_username

# Reddit API Query Parameters
REDDIT_SUBREDDIT=technology
REDDIT_TIME_FILTER=week
REDDIT_COUNT=50

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

DEBUG=False
LOG_LEVEL=INFO

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================

# Transformer model name from Hugging Face
MODEL_NAME=bert-base-uncased

# Use GPU if available
USE_GPU=True

# Embedding dimension (usually 768 for BERT)
EMBEDDING_DIM=768

# Maximum sequence length
MAX_SEQUENCE_LENGTH=128

# Batch size for processing
BATCH_SIZE=16

# Number of epochs for fine-tuning
NUM_EPOCHS=3

# ============================================================================
# SENTIMENT CLASSIFICATION CONFIGURATION
# ============================================================================

# Number of sentiment classes (3 = negative, neutral, positive)
NUM_CLASSES=3

# Sentiment labels
SENTIMENT_LABELS=negative,neutral,positive

# Model confidence threshold
CONFIDENCE_THRESHOLD=0.5

# ============================================================================
# DATA COLLECTION CONFIGURATION
# ============================================================================

# Fallback to mock data if APIs fail
USE_MOCK_DATA_ON_FAILURE=True

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Retry attempts for failed requests
RETRY_ATTEMPTS=3

# Retry delay (seconds)
RETRY_DELAY=5

# ============================================================================
# OUTPUT CONFIGURATION
# ============================================================================

# Output directory paths
DATA_DIR=data
OUTPUT_DIR=output
MODELS_DIR=models

# Save CSV exports
SAVE_CSV=True

# Create HTML dashboard
CREATE_DASHBOARD=True

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Random seed for reproducibility
RANDOM_SEED=42

# Filter options
FILTER_URLS=True
FILTER_MENTIONS=False
MIN_TEXT_LENGTH=10
MAX_TEXT_LENGTH=500

# Sentiment keywords for heuristic scoring
POSITIVE_KEYWORDS=love,great,excellent,amazing,good,fantastic,wonderful,best
NEGATIVE_KEYWORDS=hate,awful,terrible,worst,bad,horrible,poor,disappointing
NEUTRAL_KEYWORDS=data,information,report,update,article,news,content

# ============================================================================
# NOTES
# ============================================================================
# 1. Keep this file secure - it contains API credentials
# 2. Never commit .env to git - use .env.example instead
# 3. Credentials are case-sensitive
# 4. No quotes needed around values
# 5. System works without APIs - will use mock data if not configured
# 6. For development: Use mock data (leave API credentials empty)
# 7. For production: Configure real API credentials
# 8. For testing: Leave all credentials empty to use mock data
