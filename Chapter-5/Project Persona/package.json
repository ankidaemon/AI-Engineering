{
  "name": "sentiment-synthesizer",
  "version": "1.0.0",
  "description": "An NLP system to analyze and synthesize user sentiment from social media data using Transformer models",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "collect-data": "node src/dataCollection/dataCollector.js",
    "preprocess": "node src/preprocessing/preprocessor.js",
    "generate-embeddings": "node src/embedding/embeddingGenerator.js",
    "classify-sentiment": "node src/classification/sentimentClassifier.js",
    "synthesize": "node src/synthesis/sentimentSynthesizer.js",
    "visualize": "node src/visualization/visualizer.js",
    "pipeline": "npm run collect-data && npm run preprocess && npm run generate-embeddings && npm run classify-sentiment && npm run synthesize && npm run visualize"
  },
  "keywords": [
    "nlp",
    "sentiment-analysis",
    "transformers",
    "bert",
    "deep-learning",
    "social-media"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cheerio": "^1.0.0-rc.12",
    "dotenv": "^16.3.1",
    "onnxruntime-node": "^1.16.0",
    "simple-statistics": "^7.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.55.0"
  }
}
