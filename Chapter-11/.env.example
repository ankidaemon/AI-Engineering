# ─────────────────────────────────────────────────────────────────────────
# Dynamic Document Reader — environment configuration
# Copy to `.env` and adjust. Every value has a sane default in src/config.py,
# so the app runs without a .env file as long as Ollama is reachable.
# ─────────────────────────────────────────────────────────────────────────

# ── Models (Ollama) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
FAST_MODEL=llama3.1:8b          # classification, tool selection, query expansion
QUALITY_MODEL=llama3.1:70b      # analysis, synthesis, reflection
EMBEDDING_MODEL=nomic-embed-text

# ── FAISS (local vector store) ───────────────────────────────────────────
FAISS_PERSIST_DIR=./data/faiss_index
FAISS_INDEX_TYPE=Flat           # Flat (dev) | IVFFlat | HNSW (see README)

# ── Pinecone (optional, cloud vector store) ──────────────────────────────
USE_PINECONE=false
PINECONE_API_KEY=
PINECONE_INDEX=dynamic-doc-reader

# ── Retrieval ────────────────────────────────────────────────────────────
RETRIEVAL_K=8
USE_MULTI_QUERY=true
USE_HYDE=false                  # better recall, higher latency; off for existence queries
COMPRESSION_THRESHOLD=0.76

# ── Agent safety limits (never rely on the model to stop itself) ──────────
MAX_TOOL_CALLS=12               # per-agent hard cap on tool calls
MAX_AGENT_ITER=8                # supervisor hard cap on delegation rounds
MAX_REFLECTION_ITER=2           # reflection generate/critique rounds

# ── Document loading ─────────────────────────────────────────────────────
MAX_PDF_PAGES=300
MIN_PAGE_CHARS=50
UPLOAD_DIR=./data/uploads
