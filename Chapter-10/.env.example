# ─────────────────────────────────────────────────────────────────────────
# AI Workflow Designer — environment configuration
# Copy to `.env` and adjust. All values have sane defaults in src/config.py,
# so the app runs without a .env file as long as Ollama is reachable.
# ─────────────────────────────────────────────────────────────────────────

# ── LangSmith (optional, for observability) ──────────────────────────────
# Leave tracing off by default. See Chapter 10, Failure 4: synchronous
# tracing becomes a latency bottleneck under load — enable in staging, and
# sample/async-upload in production.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-workflow-designer

# ── Models (Ollama) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
PRIMARY_MODEL=llama3.1:8b      # fast: classification, routing, summarization-of-history
ADVANCED_MODEL=llama3.1:70b    # quality: analysis, risk assessment, Q&A

# ── Persistence ──────────────────────────────────────────────────────────
CHECKPOINT_DB_PATH=./data/conversations.db     # LangGraph SQLite checkpoints
CHROMA_PERSIST_DIR=./data/chroma_memory        # optional vector-store memory

# ── Behaviour ────────────────────────────────────────────────────────────
MEMORY_MAX_TOKEN_LIMIT=3000    # ConversationSummaryBufferMemory compression threshold
MAX_REVISIONS=3                # hard cap on human-review revision loops
